generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public"]
}

model Clinica {
  id          String   @id @default(uuid()) @db.Uuid
  nome        String   @db.VarChar(200)
  subdominio  String   @unique @db.VarChar(100)
  schema_name String   @unique @db.VarChar(50)
  email_admin String   @db.VarChar(200)
  status      String   @default("ativa") @db.VarChar(20)
  criada_em   DateTime @default(now())

  @@map("clinicas")
  @@schema("public")
}

model PlanoSaas {
  id                 String   @id @default(uuid()) @db.Uuid
  nome               String   @db.VarChar(100)
  preco_mensal       Decimal  @db.Decimal(10, 2)
  preco_anual        Decimal  @db.Decimal(10, 2)
  max_nutricionistas Int      @default(1)
  max_pacientes      Int      @default(100)
  ativo              Boolean  @default(true)
  criada_em          DateTime @default(now())

  @@map("planos_saas")
  @@schema("public")
}
