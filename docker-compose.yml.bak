services:

  db:
    image: postgres:16-alpine
    container_name: nutriapp-db
    restart: always
    environment:
      POSTGRES_PASSWORD: "Dnlk13"
      POSTGRES_DB: nutriapp
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 10s
      timeout: 5s
      retries: 5

  redis:
    image: redis:7-alpine
    container_name: nutriapp-redis
    restart: always
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data

volumes:
  postgres_data:
  redis_data:
